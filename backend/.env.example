# Copy this file to .env and fill in real values.

# SQLAlchemy database connection string.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trimly

# Public base URL used to build short URLs (no trailing slash needed).
BASE_URL=http://localhost:8004

# Browser origins allowed to call /api/* (the Angular frontend). JSON list.
# Must match the port `ng serve` actually runs on.
CORS_ORIGINS=["http://localhost:4200"]
